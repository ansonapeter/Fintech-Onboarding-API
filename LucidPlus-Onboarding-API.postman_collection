  "item": [
    {
      "name": "Step 1 – Register User 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function () { pm.response.to.have.status(201); });",
              "pm.test('Registration successful', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.success).to.be.true;",
              "  pm.expect(json.message).to.include('OTP');",
              "  var otpMatch = json.message.match(/OTP: (\\d+)/);",
              "  if (otpMatch) { pm.collectionVariables.set('user1_otp', otpMatch[1]); console.log('User 1 OTP saved:', otpMatch[1]); }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@gmail.com\",\n    \"mobile\": \"{{user1_mobile}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/register",
          "host": ["{{base_url}}"],
          "path": ["api", "register"]
        },
        "description": "Registers User 1. The OTP is returned in the response message and auto-saved to collection variable 'user1_otp'."
      },
      "response": [
        {
          "name": "Success",
          "status": "Created",
          "code": 201,
          "body": "{\n    \"success\": true,\n    \"message\": \"User registered. OTP: 206365\",\n    \"data\": null\n}"
        }
      ]
    },
