              "  pm.expect(json.message).to.include('successful');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"senderId\": 1,\n    \"receiverId\": 2,\n    \"amount\": 200\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/transfer",
          "host": ["{{base_url}}"],
          "path": ["api", "transfer"]
        },
        "description": "Transfers ₹200 from User 1 (account 1) to User 2 (account 2). JWT token is auto-injected from the saved variable. Uses @Transactional to ensure atomic debit and credit."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n    \"success\": true,\n    \"message\": \"Transfer successful\",\n    \"data\": null\n}"
        },
        {
          "name": "Insufficient Balance",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n    \"success\": false,\n    \"message\": \"Insufficient balance\",\n    \"data\": null\n}"
        },
        {
          "name": "Self Transfer Error",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n    \"success\": false,\n    \"message\": \"Cannot transfer to yourself\",\n    \"data\": null\n}"
