    {
      "name": "Step 6 – Transfer Money",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Transfer successful', function () {",
              "  var json = pm.response.json();",
