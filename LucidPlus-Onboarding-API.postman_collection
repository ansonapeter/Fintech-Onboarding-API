    {
      "name": "Step 5 – Login (User 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('JWT token received and saved', function () {",
